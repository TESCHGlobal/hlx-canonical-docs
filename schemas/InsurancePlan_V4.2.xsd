	<xs:complexType name="address">
		<xs:sequence>
			<xs:element name="use" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Purpose of this address.  A full list can be found here:  https://www.hl7.org/fhir/valueset-address-use.html
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="home"/>
						<xs:enumeration value="work"/>
						<xs:enumeration value="temp"/>
						<xs:enumeration value="old"/>
						<xs:enumeration value="billing"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="type" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						The address type.  A full list can be found here:  https://www.hl7.org/fhir/valueset-address-type.html
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="postal"/>
						<xs:enumeration value="physical"/>
						<xs:enumeration value="both"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<!--Text representation of the address-->
			<xs:element name="text" type="string" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						The full text representation of the address
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<!--Street name, number, direction & P.O. Box etc.-->
			<xs:element name="line" type="string" minOccurs="1" maxOccurs="unbounded"/>
			<xs:element name="city" type="string" minOccurs="1" maxOccurs="1"/>
			<xs:element name="district" type="string" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						District name (aka County)
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<!--Sub-unit of country (abbreviations ok)-CodeableConcept-USPS Two Letter Alphabetic Codes -->
			<xs:element name="state" type="string" minOccurs="1" maxOccurs="1"/>
			<xs:element name="postal_code" type="string" minOccurs="1" maxOccurs="1"/>
			<xs:element name="country" type="string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
				<xs:annotation>
					<xs:documentation>
						Time period when address was/is in use
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="geo_locations" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="geo_location" minOccurs="0" maxOccurs="unbounded">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="latitude" type="decimal" minOccurs="1" maxOccurs="1"/>
									<xs:element name="longitude" type="decimal" minOccurs="1" maxOccurs="1"/>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="period">
		<xs:sequence>
			<xs:element name="start" type="dateTime" minOccurs="0" maxOccurs="1"/>
			<xs:element name="end" type="dateTime" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="telecom">
		<xs:sequence>
			<xs:element name="system" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						use this element to describe the contact point.  https://www.hl7.org/fhir/valueset-contact-point-system.html
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="phone"/>
						<xs:enumeration value="fax"/>
						<xs:enumeration value="email"/>
						<xs:enumeration value="pager"/>
						<xs:enumeration value="url"/>
						<xs:enumeration value="sms"/>
						<xs:enumeration value="other"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<!--	The actual contact point details-->
			<xs:element name="value" type="string" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						The actual value of the contact point
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="use" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						The use of the contact point.  https://www.hl7.org/fhir/valueset-contact-point-use.html
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="home"/>
						<xs:enumeration value="work"/>
						<xs:enumeration value="temp"/>
						<xs:enumeration value="old"/>
						<xs:enumeration value="mobile"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="rank" type="positiveInt" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Specify preferred order of use (1 = highest)
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<!--Time period when the contact point was/is in use-->
			<xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
				<xs:annotation>
					<xs:documentation>
						Time period when the contact point was/is in use
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="contactpoint_available_times" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="contactpoint_available_time" minOccurs="0" maxOccurs="unbounded" type="available_time"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="via_intermediaries" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="via_intermediary" minOccurs="0" maxOccurs="unbounded">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="name" type="string" minOccurs="1" maxOccurs="1"/>
									<xs:element name="telecom" minOccurs="0" maxOccurs="unbounded">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="system" minOccurs="1" maxOccurs="1">
													<xs:annotation>
														<xs:documentation>
												The use of the contact point.  http://hl7.org/fhir/R4/valueset-contact-point-system.html
											</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="string">
															<xs:enumeration value="phone"/>
															<xs:enumeration value="fax"/>
															<xs:enumeration value="email"/>
															<xs:enumeration value="pager"/>
															<xs:enumeration value="url"/>
															<xs:enumeration value="sms"/>
															<xs:enumeration value="other"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:element>
												<xs:element name="value" type="string" minOccurs="1" maxOccurs="1">
													<xs:annotation>
														<xs:documentation>
												The actual value of the contact point
											</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="organization">
		<xs:sequence>
			<!--Unique Identifer-->
			<xs:element name="unique_identifier" type="resource_id" minOccurs="1" maxOccurs="1"/>
			<xs:element name="npi" type="NPI" minOccurs="0" maxOccurs="1"/>
			<xs:element name="clia" type="string" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Clinical Laboratory Improvement Amendments (CLIA) Number for laboratories
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="is_active" type="boolean" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Whether the organization&apos;s record is still in active use
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="types" minOccurs="1" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="type" minOccurs="1" maxOccurs="unbounded" type="type_of_organization">
							<xs:annotation>
								<xs:documentation>
						Organization type, a full list can be found here:  https://build.fhir.org/ig/HL7/davinci-pdex-plan-net/ValueSet-OrgTypeVS.html
					</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="name" type="string" minOccurs="1" maxOccurs="1"/>
			<!--A list of alternate names that the organization is known as, or was known as in the past-->
			<xs:element name="alias" type="string" minOccurs="0" maxOccurs="unbounded"/>
			<!--Organization Description-->
			<xs:element name="org_description" type="string" minOccurs="0" maxOccurs="1"/>
			<!--The organization of which this organization forms a part-->
			<xs:element name="part_of" minOccurs="0" maxOccurs="1" type="organization_part_of"/>
			<xs:element name="telecoms" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="telecom" minOccurs="0" maxOccurs="unbounded" type="telecom"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="addresses" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="address" minOccurs="0" maxOccurs="unbounded" type="address"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="organization_part_of">
		<xs:sequence>
			<!--Unique Identifer-->
			<xs:element name="unique_identifier" type="resource_id" minOccurs="1" maxOccurs="1"/>
			<xs:element name="npi" type="NPI" minOccurs="0" maxOccurs="1"/>
			<xs:element name="clia" type="string" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Clinical Laboratory Improvement Amendments (CLIA) Number for laboratories
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="is_active" type="boolean" minOccurs="1" maxOccurs="1">
				<xs:annotation>
