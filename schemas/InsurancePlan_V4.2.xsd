<?xml version="1.0" encoding="utf-8"?>

<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified"
	xmlns:xs="http://www.w3.org/2001/XMLSchema" version="4.1">
	<!--Data Type Declaration-->
	<!--Regular Expression for string-->
	<xs:simpleType name="string">
		<xs:restriction base="xs:string">
			<xs:pattern value="[ \r\n\t\S]+"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for NPI-->
	<xs:simpleType name="NPI">
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9]{10}"/>
		</xs:restriction>
	</xs:simpleType>
		<!--Regular Expression for Network_ID-->
	<xs:simpleType name="network_id">
		<xs:restriction base="xs:string">
			<xs:pattern value="[A-Za-z0-9\-\.]{1,64}"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for resource_id-->
	<xs:simpleType name="resource_id">
		<xs:restriction base="xs:string">
			<xs:pattern value="[A-Za-z0-9\-\.]{1,64}"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for Positive Integer-->
	<xs:simpleType name="positiveInt">
		<xs:restriction base="xs:positiveInteger">
			<xs:pattern value="\+?[1-9][0-9]*"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for unsignedInt Integer-->
	<xs:simpleType name="unsignedInt">
		<xs:restriction base="xs:unsignedInt">
			<xs:pattern value="0|([1-9][0-9]*)"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for Integer-->
	<xs:simpleType name="integer">
		<xs:restriction base="xs:integer">
			<xs:pattern value="[0]|[-+]?[1-9][0-9]*"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for Time-->
	<xs:simpleType name="time">
		<xs:restriction base="xs:time">
			<xs:pattern value="([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\.\d{1,9})?"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for DateTime-->
	<xs:simpleType name="dateTime">
		<xs:restriction base="xs:string">
			<xs:pattern value="([12]\d{3})-(0[1-9]|1[0-2])-(0[1-9]|[1-2][0-9]|3[0-1])(T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\.\d{1,6})?((Z|(\+|-)((0[0-9]|1[0-3]):(00|15|30|45)|14:00))?))?"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for Date-->
	<xs:simpleType name="date">
		<xs:restriction base="xs:date">
			<xs:pattern value="([12]\d{3}-(0[1-9]|1[0-2])-(0[1-9]|[12]\d|3[01]))"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for Decimal-->
	<xs:simpleType name="decimal">
		<xs:restriction base="xs:decimal">
			<xs:pattern value="-?(0|[1-9][0-9]*)(\.[0-9]+)?([eE][+-]?[0-9]+)?"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Regular Expression for Boolean-->
	<xs:simpleType name="boolean">
		<xs:restriction base="xs:boolean">
			<xs:pattern value="true|false"/>
		</xs:restriction>
	</xs:simpleType>
	<!--Data Types-->
	<xs:complexType name="identifier">
		<xs:sequence>
			<xs:element name="value" type="string" minOccurs="1" maxOccurs="1"/>
			<xs:element name="type" type="string" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="human_name">
		<xs:sequence>
			<xs:element name="use" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
					use this element to describe the name.  More information can be found here:  http://hl7.org/fhir/R4/valueset-name-use.html
				</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="usual"/>
						<xs:enumeration value="official"/>
						<xs:enumeration value="temp"/>
						<xs:enumeration value="nickname"/>
						<xs:enumeration value="anonymous"/>
						<xs:enumeration value="old"/>
						<xs:enumeration value="maiden"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element minOccurs="0" maxOccurs="1" name="text" type="string"/>
			<xs:element name="family" type="string" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						family name (often called &apos;Surname&apos;) 
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="given" type="string" maxOccurs="unbounded" minOccurs="0">
				<xs:annotation>
					<xs:documentation>
						Given names (not always &apos;first&apos;). Includes middle names
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element maxOccurs="unbounded" minOccurs="0" name="prefix" type="string"/>
			<xs:element maxOccurs="unbounded" minOccurs="0" name="suffix" type="string"/>
			<xs:element maxOccurs="1" minOccurs="0" name="period" type="period">
				<xs:annotation>
					<xs:documentation>
					Time period when name was/is in use.  If the name is still in use, do not supply an End date
				</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
