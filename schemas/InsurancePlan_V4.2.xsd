		<xs:sequence>
			<xs:element name="longitude" type="decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="latitude" type="decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="altitude" type="decimal" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
