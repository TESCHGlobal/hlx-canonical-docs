  <xs:complexType name="human_name">
    <xs:sequence>
      <!--Choose from code ValueSet- usual | official | temp | nickname | anonymous | old | maiden-->
      <xs:element name="use" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Use this element to describe the name.  More information can be found here:  http://hl7.org/fhir/R4/valueset-name-use.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="usual"/>
            <xs:enumeration value="official"/>
            <xs:enumeration value="temp"/>
            <xs:enumeration value="nickname"/>
            <xs:enumeration value="anonymous"/>
            <xs:enumeration value="old"/>
            <xs:enumeration value="maiden"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Text representation of the full name-->
      <xs:element name="text" type="string" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Use this element to enter the entire name
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Family name (often called 'Surname')-->
      <xs:element name="family" type="string" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Family name (often called 'Surname') 
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Given names (not always 'first'). Includes middle names,Given Names appear in the correct order for presenting the name-->
      <xs:element name="given" type="string" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
						Given names (not always 'first'). Includes middle names
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Parts that come before the name-->
      <xs:element name="prefix" type="string" minOccurs="0" maxOccurs="unbounded"/>
      <!--	Parts that come after the name-->
      <xs:element name="suffix" type="string" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
        <xs:annotation>
          <xs:documentation>
						Time period when name was/is in use.  If the name is still in use, do not supply an End date
					</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="address">
    <xs:sequence>
      <!--Choose from code ValueSet- home | work | temp | old | billing - purpose of this address-->
      <xs:element name="use" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						The use of this address.  More information can be found here:  http://hl7.org/fhir/R4/valueset-address-use.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="home"/>
            <xs:enumeration value="work"/>
            <xs:enumeration value="temp"/>
            <xs:enumeration value="old"/>
            <xs:enumeration value="billing"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Choose from code ValueSet- postal | physical | both-->
      <xs:element name="type" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						The type of address.  More information can be found here:  http://hl7.org/fhir/R4/valueset-address-type.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="postal"/>
            <xs:enumeration value="physical"/>
            <xs:enumeration value="both"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Text representation of the address-->
      <xs:element name="text" type="string" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Use this element to list the address in it's entirety (e.g. 123 Test Way City, State 12345)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Street name, number, direction & P.O. Box etc.-->
      <xs:element name="line" type="string" minOccurs="1" maxOccurs="unbounded"/>
      <xs:element name="city" type="string" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Name of city, town etc.
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--District name (aka county)-->
      <xs:element name="district" maxOccurs="1" minOccurs="0" type="string">
        <xs:annotation>
          <xs:documentation>
						Use this element to list the District name (aka county)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="state" type="string" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Sub-unit of country (abbreviations ok)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="postal_code" type="string" maxOccurs="1" minOccurs="1">
        <xs:annotation>
          <xs:documentation>
						The postal code or post code of the address.  The postal code supports an unlimited amount of numbers and letters.
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="country" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Country (e.g. can be ISO 3166 2 or 3 letter code)
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="2"/>
            <xs:maxLength value="3"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Time period when address was/is in use-->
      <xs:element name="period" minOccurs="0" maxOccurs="1" type="period"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="telecom">
    <xs:sequence>
      <xs:element name="system" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Use this element to describe the contact point.  https://www.hl7.org/fhir/valueset-contact-point-system.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="phone"/>
            <xs:enumeration value="fax"/>
            <xs:enumeration value="email"/>
            <xs:enumeration value="pager"/>
            <xs:enumeration value="url"/>
            <xs:enumeration value="sms"/>
            <xs:enumeration value="other"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--	The actual contact point details-->
      <xs:element name="value" type="string" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						The actual value of the contact point
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="use" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						The use of the contact point.  https://www.hl7.org/fhir/valueset-contact-point-use.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="home"/>
            <xs:enumeration value="work"/>
            <xs:enumeration value="temp"/>
            <xs:enumeration value="old"/>
            <xs:enumeration value="mobile"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="rank" type="positiveInt" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Specify preferred order of use (1 = highest)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Time period when the contact point was/is in use-->
      <xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
        <xs:annotation>
          <xs:documentation>
						Time period when the contact point was/is in use
					</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="period">
    <xs:sequence>
      <xs:element name="start" type="dateTime" minOccurs="1" maxOccurs="1"/>
      <xs:element name="end" type="dateTime" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="range">
    <xs:sequence>
      <xs:element name="low" minOccurs="0" maxOccurs="1" type="simple_quantity"/>
      <xs:element name="high" minOccurs="0" maxOccurs="1" type="simple_quantity"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="codeable_concept">
    <xs:sequence>
      <xs:element name="coding" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:all>
            <xs:element name="system" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="version" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
          </xs:all>
        </xs:complexType>
      </xs:element>
      <xs:element name="text" type="string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="result_value">
    <xs:choice>
      <xs:element name="value_quantity" type="quantity" minOccurs="0" maxOccurs="1"/>
      <xs:element name="value_codeable_concept" type="codeable_concept" minOccurs="0" maxOccurs="1"/>
      <xs:element name="value_boolean" type="boolean" minOccurs="0" maxOccurs="1"/>
      <xs:element name="value_string" type="string" minOccurs="0" maxOccurs="1"/>
      <xs:element name="value_integer" type="integer" minOccurs="0" maxOccurs="1"/>
      <xs:element name="value_range" type="range" minOccurs="0" maxOccurs="1"/>
      <xs:element name="value_ratio" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="numerator" type="quantity" minOccurs="0" maxOccurs="1"/>
            <xs:element name="denominator" type="quantity" minOccurs="0" maxOccurs="1"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
