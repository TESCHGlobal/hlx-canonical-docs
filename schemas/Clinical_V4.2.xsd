  <xs:complexType name="encounter">
    <xs:sequence>
      <xs:element name="identifier" type="string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
							Identifier(s) by which this encounter is known
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="status" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
							planned | arrived | triaged | in-progress | onleave | finished | cancelled +
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="planned"/>
            <xs:enumeration value="arrived"/>
            <xs:enumeration value="triaged"/>
            <xs:enumeration value="in-progress"/>
            <xs:enumeration value="onleave"/>
            <xs:enumeration value="finished"/>
            <xs:enumeration value="cancelled"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="class" type="string" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
							Classification of patient encounter
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="type" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
							Specific type of encounter
					</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="code" type="string" minOccurs="1" maxOccurs="1"/>
            <xs:element name="system" minOccurs="1" maxOccurs="1">
              <xs:simpleType>
                <xs:restriction base="string">
                  <xs:enumeration value="http://snomed.info/sct"/>
                  <xs:enumeration value="http://www.ama-assn.org/go/cpt"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="version" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="text" type="string" minOccurs="0" maxOccurs="1"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="participants" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="participant" minOccurs="0" maxOccurs="unbounded">
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="type" minOccurs="0" maxOccurs="unbounded">
                    <xs:complexType>
                      <xs:sequence>
                        <xs:element name="code" minOccurs="0" maxOccurs="1" type="string"/>
                        <xs:element name="system" minOccurs="0" maxOccurs="1">
                          <xs:simpleType>
                            <xs:restriction base="string">
                              <xs:enumeration
                                value="http://terminology.hl7.org/CodeSystem/v3-ParticipationType"/>
                              <xs:enumeration
                                value="http://terminology.hl7.org/CodeSystem/participant-type"/>
                            </xs:restriction>
                          </xs:simpleType>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="period" minOccurs="0" maxOccurs="1" type="period"/>
                  <xs:element name="individual" minOccurs="0" maxOccurs="1" type="practitioner"/>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
        <xs:annotation>
          <xs:documentation>
							The start and end time of the encounter
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="reason_code" minOccurs="0" maxOccurs="unbounded" type="string">
        <xs:annotation>
          <xs:documentation>
							The start and end time of the encounter
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="hospitalization" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="discharge_disposition" minOccurs="0" maxOccurs="1"
              type="codeable_concept"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="diagnoses" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="diagnosis" minOccurs="1" maxOccurs="unbounded">
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="condition" minOccurs="1" maxOccurs="1" type="condition"/>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="locations" minOccurs="1" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="location" minOccurs="0" maxOccurs="unbounded" type="location"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="condition">
    <xs:sequence>
      <xs:element name="unique_identifier" minOccurs="1" maxOccurs="1" type="string"/>
      <xs:element name="care_plan_id" minOccurs="0" maxOccurs="1" type="string" />
      <xs:element name="condition_code" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            Identification of the condition, problem or diagnosis. 
            A detailed list of codes can be found here http://hl7.org/fhir/us/core/ValueSet-us-core-condition-code.html
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="system" minOccurs="0" maxOccurs="1">
              <xs:simpleType>
                <xs:restriction base="string">
                  <xs:enumeration value="http://snomed.info/sct"/>
                  <xs:enumeration value="http://hl7.org/fhir/sid/icd-10-cm"/>
                  <xs:enumeration value="http://hl7.org/fhir/sid/icd-9-cm"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="version" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="text" type="string" minOccurs="0" maxOccurs="1"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="1" maxOccurs="unbounded" name="category">
        <xs:annotation>
          <xs:documentation>
            Identification of the condition, problem or diagnosis
          </xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="problem-list-item"/>
            <xs:enumeration value="encounter-diagnosis"/>
            <xs:enumeration value="health-concern"/>
            <xs:enumeration value="sdoh"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="clinical_status">
        <xs:annotation>
          <xs:documentation>
            Preferred value set for Condition Clinical Status
          </xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="active"/>
            <xs:enumeration value="recurrence"/>
            <xs:enumeration value="relapse"/>
            <xs:enumeration value="inactive"/>
            <xs:enumeration value="remission"/>
            <xs:enumeration value="resolved"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="verification_status" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The verification status to support or decline the clinical status of the condition or diagnosis.
          </xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="unconfirmed"/>
            <xs:enumeration value="provisional"/>
            <xs:enumeration value="differential"/>
            <xs:enumeration value="confirmed"/>
            <xs:enumeration value="refuted"/>
            <xs:enumeration value="entered-in-error"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Who has the condition?-->
      <!--<xs:element name="subject" minOccurs="1" maxOccurs="1" type="member_person"/>-->
      <xs:element name="severity" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            Subjective severity of condition
          </xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="severe"/>
            <xs:enumeration value="moderate"/>
            <xs:enumeration value="mild"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="onset" type="onset" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            Estimated or actual date, date-time, or age
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="recorded_date" type="dateTime" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            Date of when condition was first recorded,The recordedDate represents when this particular Condition record was created in the system, which is often a system-generated date.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="specimen" maxOccurs="1" minOccurs="0">
        <xs:annotation>
          <xs:documentation>(USCDI) Specimen used for this observation.</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="reference" minOccurs="0" maxOccurs="1" type="string"/>
            <xs:element name="status" minOccurs="0" maxOccurs="1">
              <xs:simpleType>
                <xs:restriction base="string">
                  <xs:enumeration value="available"/>
                  <xs:enumeration value="unavailable"/>
                  <xs:enumeration value="unsatisfactory"/>
                  <xs:enumeration value="entered-in-error"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:element>
            <xs:element name="type" minOccurs="0" maxOccurs="1" type="codeable_concept"/>
            <xs:element name="identifier" minOccurs="0" maxOccurs="1" type="string"/>
            <xs:element name="display" minOccurs="0" maxOccurs="1" type="string"/>
            <xs:element name="receivedDateTime" minOccurs="0" maxOccurs="1" type="dateTime"/>
            <xs:element name="collection" maxOccurs="1" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Collection details.</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:sequence>
                  <xs:annotation>
                    <xs:documentation>Collection details.</xs:documentation>
                  </xs:annotation>
                  <xs:element name="collectionDateTime" minOccurs="0" maxOccurs="1" type="dateTime"/>
                  <xs:element name="quantity" minOccurs="0" maxOccurs="1">
                    <xs:complexType>
                      <xs:sequence>
                        <xs:element name="value" minOccurs="0" maxOccurs="1" type="integer"/>
                        <xs:element name="unit" minOccurs="0" maxOccurs="1" type="string"/>
                        <xs:element name="system" minOccurs="0" maxOccurs="1" type="string"/>
                        <xs:element name="code" minOccurs="0" maxOccurs="1" type="string"/>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="method" minOccurs="0" maxOccurs="1" type="codeable_concept">
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="abatement" type="abatement" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            The date or estimated date that the condition resolved or went into remission. This is called "abatement" because of the many overloaded connotations associated with "remission" or "resolution" - Conditions are never really resolved, but they can abate.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="record_type">
        <xs:annotation>
          <xs:documentation>
            This element describes the action for this profile (A = Add, U = Update, D = Delete)
          </xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="A"/>
            <xs:enumeration value="U"/>
            <xs:enumeration value="D"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
