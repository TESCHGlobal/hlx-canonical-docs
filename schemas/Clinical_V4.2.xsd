  <xs:group name="organization">
    <xs:sequence>
      <xs:element name="organization" minOccurs="1" maxOccurs="1" type="organization"/>
    </xs:sequence>
  </xs:group>
  <xs:group name="related_person">
    <xs:sequence>
      <xs:element name="related_person" type="related_person" minOccurs="1" maxOccurs="1"/>
    </xs:sequence>
  </xs:group>
  <xs:element name="clinicals">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="1" minOccurs="1" name="schema_version">
          <xs:annotation>
            <xs:documentation>
                            This element defines what version of the clinical schema you will be validating against (e.g. 1.0)
                        </xs:documentation>
          </xs:annotation>
          <xs:simpleType>
            <xs:restriction base="xs:decimal">
              <xs:pattern value="([1-9]{1,2})\.([0-9]{1,2})"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:element maxOccurs="1" minOccurs="1" name="sender_id" type="string">
          <xs:annotation>
            <xs:documentation>
                            This element is used to the unique identifier assigned to your organization
                        </xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element maxOccurs="1" minOccurs="1" name="date_time_reported">
          <xs:annotation>
            <xs:documentation>
                            This element is used to the identify the date time this information was reported (e.g. 2001-10-26T21:32:52+02:00)
                        </xs:documentation>
          </xs:annotation>
          <xs:simpleType>
            <xs:restriction base="xs:dateTime">
              <xs:pattern
                value="([12]\d{3})-(0[1-9]|1[0-2])-(0[1-9]|[1-2][0-9]|3[0-1])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\.\d{1,9})?(Z|(\+|-)((0[0-9]|1[0-3]):(00|15|30|45)|14:00))"
              />
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:element maxOccurs="unbounded" minOccurs="1" name="clinical">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="patient">
                <xs:complexType>
                  <xs:choice>
                    <xs:group ref="member_person_group"/>
                    <xs:element name="reference" type="reference"/>
                  </xs:choice>
                </xs:complexType>
              </xs:element>
              <xs:element name="lab_observations" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="lab_observation" minOccurs="1" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="unique_identifier" minOccurs="1" maxOccurs="1"
                            type="string"/>
                          <xs:element name="status" maxOccurs="1" minOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                Status of the observation
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="registered"/>
                                <xs:enumeration value="preliminary"/>
                                <xs:enumeration value="final"/>
                                <xs:enumeration value="amended"/>
                                <xs:enumeration value="corrected"/>
                                <xs:enumeration value="cancelled"/>
                                <xs:enumeration value="entered-in-error"/>
                                <xs:enumeration value="unknown"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <!--hardcoded value-->
                          <!--<xs:element name="category" minOccurs="1" maxOccurs="unbounded" type="string"/>-->
                          <xs:element name="observation_code" type="codeable_concept" minOccurs="1"
                            maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
																	Laboratory Test Name [LOINC COdes]
															</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--<xs:element name="subject" minOccurs="1" maxOccurs="1" type="member_person"/>-->
                          <xs:element name="observation_effective" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:choice>
                                  <xs:element name="effective_date_time" minOccurs="0" maxOccurs="1"
                                    type="dateTime">
                                    <xs:annotation>
                                      <xs:documentation>
                                                                            Clinically relevant time/time-period for observation
                                                                        </xs:documentation>
                                    </xs:annotation>
                                  </xs:element>
                                  <xs:element name="effective_period" minOccurs="0" maxOccurs="1"
                                    type="period"/>
                                </xs:choice>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:choice>
                            <xs:element name="observation_value" minOccurs="0" maxOccurs="1"
                              type="result_value">
                              <xs:annotation>
                                <xs:documentation>
	                                                                Result of the observation
	                                                            </xs:documentation>
                              </xs:annotation>
                            </xs:element>
                            <xs:element name="data_absent_reason" maxOccurs="1" minOccurs="0">
                              <xs:annotation>
                                <xs:documentation>
	                                                                Reason for missing data. Inputs can be found here: http://hl7.org/fhir/R4/valueset-data-absent-reason.html
	                                                            </xs:documentation>
                              </xs:annotation>
                              <xs:simpleType>
                                <xs:restriction base="string">
                                  <xs:enumeration value="unknown"/>
                                  <xs:enumeration value="asked-unknown"/>
                                  <xs:enumeration value="temp-unknown"/>
                                  <xs:enumeration value="not-asked"/>
                                  <xs:enumeration value="asked-declined"/>
                                  <xs:enumeration value="masked"/>
                                  <xs:enumeration value="not-applicable"/>
                                  <xs:enumeration value="unsupported"/>
                                  <xs:enumeration value="as-text"/>
                                  <xs:enumeration value="error"/>
                                  <xs:enumeration value="not-a-number"/>
                                  <xs:enumeration value="negative-infinity"/>
                                  <xs:enumeration value="positive-infinity"/>
                                  <xs:enumeration value="not-performed"/>
                                  <xs:enumeration value="not-permitted"/>
                                </xs:restriction>
                              </xs:simpleType>
                            </xs:element>
                          </xs:choice>
                          <xs:element name="interpretation" minOccurs="0" maxOccurs="unbounded"
                            type="string">
                            <xs:annotation>
                              <xs:documentation>	
																A categorical assessment of an observation value. For example, high, low, normal.
                                                            </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="reference_range" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>		
															Guidance on how to interpret the value by comparison to a normal or recommended range. Multiple reference ranges are interpreted as an "OR". In other words, to represent two distinct target populations, two referenceRange elements would be used.
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="low" minOccurs="0" maxOccurs="1"
                                  type="simple_quantity"/>
                                <xs:element name="high" minOccurs="0" maxOccurs="1"
                                  type="simple_quantity"/>
                                <xs:element name="type" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="normal"/>
                                      <xs:enumeration value="recommended"/>
                                      <xs:enumeration value="treatment"/>
                                      <xs:enumeration value="therapeutic"/>
                                      <xs:enumeration value="pre_therapeutic"/>
                                      <xs:enumeration value="post_therapeutic"/>
                                      <xs:enumeration value="endocrine"/>
                                      <xs:enumeration value="pre-puberty"/>
                                      <xs:enumeration value="follicular"/>
                                      <xs:enumeration value="midcycle"/>
                                      <xs:enumeration value="luteal"/>
                                      <xs:enumeration value="postmenopausal"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                                <xs:element name="applies_to" minOccurs="0" maxOccurs="1"
                                  type="codeable_concept"/>
                                <xs:element name="age" minOccurs="0" maxOccurs="1" type="range"/>
                                <xs:element name="text" minOccurs="0" maxOccurs="1" type="string"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="0" name="record_type">
                            <xs:annotation>
                              <xs:documentation>
																This element describes the action for this profile (A = Add, U = Update, D = Delete)
															</xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="A"/>
                                <xs:enumeration value="U"/>
                                <xs:enumeration value="D"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="allergy_intolerances" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="allergy_intolerance" minOccurs="1" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="unique_identifier" minOccurs="1" maxOccurs="1"
                            type="string"/>
                          <xs:element name="clinical_status" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                The clinical status of the allergy or intolerance.
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="active"/>
                                <xs:enumeration value="inactive"/>
                                <xs:enumeration value="resolved"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="verification_status" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                Assertion about certainty associated with the propensity, or potential risk, of a reaction to the identified substance (including pharmaceutical product).
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="unconfirmed"/>
                                <xs:enumeration value="confirmed"/>
                                <xs:enumeration value="refuted"/>
                                <xs:enumeration value="entered-in-error"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="type" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                Identification of the underlying physiological mechanism for the reaction risk.
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="allergy"/>
                                <xs:enumeration value="intolerance"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="category" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
                                                                The category of the allergy from the type of allergen item.
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="food"/>
                                <xs:enumeration value="medication"/>
                                <xs:enumeration value="environment"/>
                                <xs:enumeration value="biologic"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="allergy_code" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                            Code for an allergy or intolerance statement (either a positive or a negated/excluded statement). This may be a code for a substance or pharmaceutical product that is considered to be responsible for the adverse reaction risk (e.g., "Latex"), an allergy or intolerance condition (e.g., "Latex allergy"), or a negated/excluded code for a specific substance or class (e.g., "No latex allergy") or a general or categorical negated statement (e.g., "No known allergy", "No known drug allergies").
                                                                        </xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="http://snomed.info/sct"/>
                                      <xs:enumeration
                                        value="http://www.nlm.nih.gov/research/umls/rxnorm"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                                <xs:element name="version" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="text" type="string" minOccurs="0" maxOccurs="1"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <!--<xs:element name="patient" minOccurs="1" maxOccurs="1" type="member_person"/>-->
                          <xs:element name="reactions" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="reaction" minOccurs="0" maxOccurs="unbounded">
                                  <xs:annotation>
                                    <xs:documentation>
                                                                            Details about each adverse reaction event linked to exposure to the identified substance.
                                                                        </xs:documentation>
                                  </xs:annotation>
                                  <xs:complexType>
                                    <xs:sequence>
                                      <xs:element name="manifestation" minOccurs="1"
                                        maxOccurs="unbounded" type="string">
                                        <xs:annotation>
                                          <xs:documentation>
																						Clinical symptoms and/or signs that are observed or associated with the adverse reaction event.
																					</xs:documentation>
                                        </xs:annotation>
                                      </xs:element>
                                    </xs:sequence>
                                  </xs:complexType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="onset" type="onset" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                When allergy or intolerance was identified
                                                            </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="criticality" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                	
																Estimate of the potential clinical harm, or seriousness, of the reaction to the identified substance.
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="low"/>
                                <xs:enumeration value="high"/>
                                <xs:enumeration value="unable-to-assess"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="recorded_date" type="dateTime" minOccurs="0"
                            maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                The recordedDate represents when this particular AllergyIntolerance record was created in the system, which is often a system-generated date.
                                                            </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="0" name="record_type">
                            <xs:annotation>
                              <xs:documentation>
																This element describes the action for this profile (A = Add, U = Update, D = Delete)
															</xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="A"/>
                                <xs:enumeration value="U"/>
                                <xs:enumeration value="D"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="conditions" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="condition" minOccurs="1" maxOccurs="unbounded"
                      type="condition"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="procedures" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="procedure" minOccurs="1" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="unique_identifier" minOccurs="1" maxOccurs="1"
                            type="string"/>
                          <xs:element name="procedure_code" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                - Procedure codes from SNOMED CT, CPT, HCPCS II, ICD-10-PCS, or CDT.
                                - HCPCS Level II Alphanumeric Codes are maintained by CMS and are available for public use.
                                - Refer to urn:oid:2.16.840.1.113883.6.285 for HCPCS Level II codes.
                              </xs:documentation>
                            </xs:annotation>

                            <xs:complexType>
                              <xs:sequence>

                                <xs:choice>

                                  <!-- Option 1: Standard code+system (+optional version/display) -->
                                  <xs:sequence>
                                    <xs:element name="code" type="xs:string" minOccurs="1"
                                      maxOccurs="1"/>

                                    <xs:element name="system" minOccurs="1" maxOccurs="1">
                                      <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                          <xs:enumeration value="http://www.ama-assn.org/go/cpt"/>
                                          <xs:enumeration value="http://snomed.info/sct"/>
                                          <xs:enumeration
                                            value="http://www.cms.gov/Medicare/Coding/ICD10"/>
                                          <xs:enumeration
                                            value="http://terminology.hl7.org/CodeSystem/CD2"/>
                                          <xs:enumeration value="urn:oid:2.16.840.1.113883.6.285"/>
                                        </xs:restriction>
                                      </xs:simpleType>
                                    </xs:element>

                                    <xs:element name="version" type="xs:string" minOccurs="0"
                                      maxOccurs="1"/>
                                    <xs:element name="display" type="xs:string" minOccurs="0"
                                      maxOccurs="1"/>
                                  </xs:sequence>

                                  <!-- Option 2: extensions only (one or more) -->
                                  <xs:sequence>
                                    <xs:element name="extension" minOccurs="1" maxOccurs="unbounded">
                                      <xs:complexType>
                                        <xs:sequence>
                                          <xs:element name="url" type="xs:anyURI" minOccurs="1"
                                            maxOccurs="1"/>
                                          <xs:element name="valueCode" type="xs:string"
                                            minOccurs="1" maxOccurs="1"/>
                                        </xs:sequence>
                                      </xs:complexType>
                                    </xs:element>
                                  </xs:sequence>

                                </xs:choice>

                                <!-- Optional narrative text (allowed with either option) -->
                                <xs:element name="text" type="xs:string" minOccurs="0" maxOccurs="1"/>

                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>

                          <xs:element name="status" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
																A code specifying the state of the procedure. Generally, this will be the in-progress or completed state.
															</xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="preparation"/>
                                <xs:enumeration value="in-progress"/>
                                <xs:enumeration value="not-done"/>
                                <xs:enumeration value="on-hold"/>
                                <xs:enumeration value="stopped"/>
                                <xs:enumeration value="completed"/>
                                <xs:enumeration value="entered-in-error"/>
                                <xs:enumeration value="unknown"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <!--Who the procedure was performed on-->
                          <!--<xs:element name="subject" minOccurs="1" maxOccurs="1" type="member_person"/>-->
                          <xs:element name="performed" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
																Estimated or actual date, date-time, period, or age when the procedure was performed. Allows a period to support complex procedures that span more than one date, and also allows for the length of the procedure to be captured.
															</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:choice>
                                  <xs:element name="performed_date_time" minOccurs="0" maxOccurs="1"
                                    type="dateTime"/>
                                  <xs:element name="performed_period" minOccurs="0" maxOccurs="1"
                                    type="period"/>
                                </xs:choice>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="0" name="record_type">
                            <xs:annotation>
                              <xs:documentation>
																This element describes the action for this Profile (A = Add, U = Update, D = Delete)
															</xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="A"/>
                                <xs:enumeration value="U"/>
                                <xs:enumeration value="D"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="medication_requests" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="medication_request" minOccurs="1" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="unique_identifier" minOccurs="1" maxOccurs="1"
                            type="string"/>
                          <xs:element name="status" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                Status of the request
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="active"/>
                                <xs:enumeration value="on-hold"/>
                                <xs:enumeration value="cancelled"/>
                                <xs:enumeration value="completed"/>
                                <xs:enumeration value="entered-in-error"/>
                                <xs:enumeration value="stopped"/>
                                <xs:enumeration value="draft"/>
                                <xs:enumeration value="unknown"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>

                          <xs:element name="intent" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                Intent of the request
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="proposal"/>
                                <xs:enumeration value="plan"/>
                                <xs:enumeration value="order"/>
                                <xs:enumeration value="original-order"/>
                                <xs:enumeration value="reflex-order"/>
                                <xs:enumeration value="filler-order"/>
                                <xs:enumeration value="instance-order"/>
                                <xs:enumeration value="option"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="reported" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                                Was medication reported by patient or not
                                                            </xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:choice>
                                  <xs:element name="reported_boolean" type="boolean" minOccurs="0"
                                    maxOccurs="1"/>
                                  <xs:element name="reported_reference" minOccurs="0" maxOccurs="1">
                                    <xs:complexType>
                                      <xs:sequence>
                                        <xs:choice>
                                          <xs:element name="reported_patient" minOccurs="0"
                                            maxOccurs="1" type="member_person"/>
                                          <xs:element name="reported_practitioner" minOccurs="0"
                                            maxOccurs="1" type="practitioner"/>
                                          <xs:element name="reported_organization" minOccurs="0"
