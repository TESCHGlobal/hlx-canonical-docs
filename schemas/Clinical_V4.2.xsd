										This element is used for selecting birth sex (M = Male, F = Female, UNK = Unknown)
									</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="M"/>
            <xs:enumeration value="F"/>
            <xs:enumeration value="UNK"/>
