          <xs:sequence>
            <xs:element name="communication" minOccurs="0" maxOccurs="unbounded">
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="language" minOccurs="1" maxOccurs="1">
                    <xs:annotation>
                      <xs:documentation>
											This value set includes common codes from BCP-47 (http://tools.ietf.org/html/bcp47).  More information can be found here: http://hl7.org/fhir/R4/valueset-languages.html 
										</xs:documentation>
