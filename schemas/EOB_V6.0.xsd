  <xs:element name="eob_list">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="1" minOccurs="1" name="schema_version">
          <xs:annotation>
            <xs:documentation>
							This element defines what version of the EOB schema you will be validating against (e.g. 1.0)
						</xs:documentation>
          </xs:annotation>
          <xs:simpleType>
            <xs:restriction base="xs:decimal">
              <xs:pattern value="([1-9]{1,2})\.([0-9]{1,2})"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:element maxOccurs="1" minOccurs="1" name="sender_id" type="string">
          <xs:annotation>
            <xs:documentation>
							This element is used to the unique identifier assigned to your organization
						</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element maxOccurs="1" minOccurs="1" name="date_time_reported">
          <xs:annotation>
            <xs:documentation>
							This element is used to the identify the date time this information was reported (e.g. 2001-10-26T21:32:52+02:00)
						</xs:documentation>
          </xs:annotation>
          <xs:simpleType>
            <xs:restriction base="xs:dateTime">
              <xs:pattern value="([12]\d{3})-(0[1-9]|1[0-2])-(0[1-9]|[1-2][0-9]|3[0-1])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\.\d{1,9})?(Z|(\+|-)((0[0-9]|1[0-3]):(00|15|30|45)|14:00))"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:element name="eob" minOccurs="1" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <!--An identifier for EOB-->
              <xs:element name="eob_identifier" type="eob_identifier" minOccurs="1" maxOccurs="1">
                <xs:annotation>
                  <xs:documentation>
									This is a unique business identifier assigned to the EOB.  In the event, that this EOB changes in either status or content, the replacement EOB would be expected to have the same identifier.   
									</xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element name="status" minOccurs="1" maxOccurs="1">
                <xs:annotation>
                  <xs:documentation>
							Claim processing status code 
						</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                  <xs:restriction base="string">
                    <xs:enumeration value="active"/>
                    <xs:enumeration value="cancelled"/>
                    <xs:enumeration value="draft"/>
                    <xs:enumeration value="entered-in-error"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
              <xs:element name="type" minOccurs="1" maxOccurs="1">
                <xs:annotation>
                  <xs:documentation>
										Claim type code (institutional, oral, pharmacy, professional or vision)
									</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                  <xs:restriction base="string">
                    <xs:enumeration value="institutional"/>
                    <xs:enumeration value="oral"/>
                    <xs:enumeration value="pharmacy"/>
                    <xs:enumeration value="professional"/>
                    <xs:enumeration value="vision"/>
                    <xs:enumeration value="Institutional"/>
                    <xs:enumeration value="Oral"/>
                    <xs:enumeration value="Pharmacy"/>
                    <xs:enumeration value="Professional"/>
                    <xs:enumeration value="Vision"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
              <xs:element name="sub_type" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                  <xs:documentation>
										sub type of Institutional Profiles
									</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                  <xs:restriction base="string">
                    <xs:enumeration value="inpatient"/>
                    <xs:enumeration value="outpatient"/>
                    <xs:enumeration value="Inpatient"/>
                    <xs:enumeration value="Outpatient"/>
                    <xs:enumeration value="Inpatient-Institutional"/>
                    <xs:enumeration value="Outpatient-Institutional"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
              <xs:element name="use" minOccurs="1" maxOccurs="1">
                <xs:annotation>
                  <xs:documentation>
							The purpose of the Claim: predetermination, preauthorization, claim.  More information can be found here:  http://hl7.org/fhir/R4/valueset-claim-use.html
						</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                  <xs:restriction base="string">
                    <xs:enumeration value="claim"/>
                    <xs:enumeration value="preauthorization"/>
                    <xs:enumeration value="predetermination"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
              <xs:element name="billable_period" minOccurs="0" maxOccurs="1" type="period"/>
              <xs:element name="created" type="dateTime" minOccurs="1" maxOccurs="1"/>
              <!--claim | preauthorization | predetermination-->
              <xs:element name="outcome" minOccurs="1" maxOccurs="1">
                <xs:annotation>
                  <xs:documentation>
							This value set includes Claim Processing Outcome codes.  More information can be found here:  http://hl7.org/fhir/R4/valueset-remittance-outcome.html
						</xs:documentation>
