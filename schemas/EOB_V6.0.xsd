						The actual value of the contact point
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="use" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						The use of the contact point.  https://www.hl7.org/fhir/valueset-contact-point-use.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="home"/>
            <xs:enumeration value="work"/>
            <xs:enumeration value="temp"/>
            <xs:enumeration value="old"/>
            <xs:enumeration value="mobile"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="rank" type="positiveInt" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Specify preferred order of use (1 = highest)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Time period when the contact point was/is in use-->
      <xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
        <xs:annotation>
          <xs:documentation>
						Time period when the contact point was/is in use
					</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="practitioner">
    <xs:sequence>
      <!--Claim billing provider NPI-->
      <xs:element name="npi" type="NPI" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
							National Provider Identifier (NPI)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="tax" type="string" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
							An identifier for the person as this agent

					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--The name(s) associated with the practitioner-->
      <xs:choice>
        <xs:element name="names" minOccurs="1" maxOccurs="1">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="name" minOccurs="1" maxOccurs="unbounded" type="human_name"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="reference" minOccurs="1" maxOccurs="1" type="string"/>
      </xs:choice>
      <xs:element name="telecoms" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="telecom" minOccurs="0" maxOccurs="unbounded" type="telecom"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="addresses" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="address" minOccurs="0" maxOccurs="unbounded" type="address"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="organization">
    <xs:sequence>
      <!--Claim billing provider NPI-->
      <xs:element name="npi" type="NPI" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
							National Provider Identifier (NPI)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="clia" type="string" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
							Clinical Laboratory Improvement Amendments (CLIA) Number for laboratories
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="tax" minOccurs="0" maxOccurs="unbounded" type="identifier">
        <xs:annotation>
          <xs:documentation>
							Tax Id Number
						</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="naic_code" minOccurs="0" maxOccurs="unbounded" type="identifier"/>
      <!--Payer ID-->
      <xs:element name="payer_id" minOccurs="0" maxOccurs="unbounded" type="identifier"/>
      <xs:element name="is_active" type="boolean" minOccurs="1" maxOccurs="1"/>
      <xs:element name="name" minOccurs="1" maxOccurs="1" type="string"/>
      <xs:element name="alias" type="string" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="telecoms" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="telecom" minOccurs="0" maxOccurs="unbounded" type="telecom"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="addresses" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="address" minOccurs="0" maxOccurs="unbounded" type="address"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="member_person">
    <xs:sequence>
      <xs:element maxOccurs="1" minOccurs="1" name="member_id" type="string">
        <xs:annotation>
          <xs:documentation>
						Use this element to list the Member ID . 
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="member_id_system" type="string">
        <xs:annotation>
          <xs:documentation>
						Use this element to identify the system that issues the Member ID . 
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="1" name="subscriber_id" type="string">
        <xs:annotation>
          <xs:documentation>
						Use this element to list the Subscriber ID. 
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="unique_person_id" type="string">
        <xs:annotation>
          <xs:documentation>
						This is the person's unique member number in the Payer system across plans.  This number is not reused for anyone else.
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="unique_person_id_assigner" type="string">
        <xs:annotation>
          <xs:documentation>
							Organization that issued id 
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="unique_person_id_assigner_type" type="string">
        <xs:annotation>
          <xs:documentation>
						Type of organization that issued id  
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="names" minOccurs="1" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="name" minOccurs="1" maxOccurs="unbounded" type="human_name"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="1" name="gender">
        <xs:annotation>
          <xs:documentation>
						Use this element for Gender (male, female, other or unknown)
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="male"/>
            <xs:enumeration value="female"/>
            <xs:enumeration value="other"/>
            <xs:enumeration value="unknown"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="birth_date" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Birth date (1900-01-01)
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:date">
            <xs:minInclusive value="1900-01-01"/>
            <xs:pattern value="([12]\d{3}-(0[1-9]|1[0-2])-(0[1-9]|[12]\d|3[01]))"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="marital_status" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
						Marital Status, more information can be found here:  http://hl7.org/fhir/R4/valueset-marital-status.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="A"/>
            <xs:enumeration value="D"/>
            <xs:enumeration value="I"/>
            <xs:enumeration value="L"/>
            <xs:enumeration value="M"/>
            <xs:enumeration value="P"/>
            <xs:enumeration value="S"/>
            <xs:enumeration value="T"/>
            <xs:enumeration value="U"/>
            <xs:enumeration value="W"/>
            <xs:enumeration value="UNK"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="deceased" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="is_deceased" type="boolean" minOccurs="0" maxOccurs="1"/>
            <xs:element name="deceased_date_time" type="dateTime" minOccurs="0" maxOccurs="1"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="telecoms" minOccurs="0" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="telecom" minOccurs="0" maxOccurs="unbounded" type="telecom"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="addresses" minOccurs="1" maxOccurs="1">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="address" minOccurs="1" maxOccurs="unbounded" type="address"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="communications" minOccurs="0" maxOccurs="1">
