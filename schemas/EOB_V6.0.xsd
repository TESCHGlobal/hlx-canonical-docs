                      </xs:complexType>
                    </xs:element>
                    <!--Claim payee- Reference(CARIN BB Organization |CARIN BB practitioner | CARIN BB Patient)-->
                    <xs:element name="party" minOccurs="1" maxOccurs="1">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:choice>
                            <xs:element name="reference" minOccurs="1" maxOccurs="1" type="string"/>
                            <xs:element name="practitioner" minOccurs="1" maxOccurs="1" type="practitioner"/>
                            <xs:element name="providing_organization" minOccurs="1" maxOccurs="1" type="organization"/>
                            <xs:element name="patient" minOccurs="1" maxOccurs="1" type="member_person"/>
                          </xs:choice>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="care_teams" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="care_team" minOccurs="0" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <!--Order of care team-->
                          <xs:element name="sequence" type="positiveInt" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Order of the care team
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Indicator of the lead practitioner-->
                          <xs:element name="is_responsible" type="boolean" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Is this the lead practitioner?
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--	Reference(Practitioner | PractitionerRole | Organization)-->
                          <xs:element name="provider" minOccurs="1" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:choice>
                                  <xs:element name="reference" minOccurs="1" maxOccurs="1" type="string"/>
                                  <xs:element name="practitioner" minOccurs="1" maxOccurs="1" type="practitioner"/>
                                  <xs:element name="providing_organization" minOccurs="1" maxOccurs="1" type="organization"/>
                                </xs:choice>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="role" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
									This element defines Function within the team,Enumuration set is combined list of possible code value set from each profile: 
									Inpatient-Facility and Outpatient-Facility (primary,attending,performing,referring,operating,otheroperating), 
									Pharmacy (prescribing,primary) 
									and Professional-NonClinician (primary,performing,referring,supervisor,purchasedservice)
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" minOccurs="1" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="primary"/>
                                      <xs:enumeration value="attending"/>
                                      <xs:enumeration value="referring"/>
                                      <xs:enumeration value="operating"/>
                                      <xs:enumeration value="otheroperating"/>
                                      <xs:enumeration value="performing"/>
                                      <xs:enumeration value="supervisor"/>
                                      <xs:enumeration value="purchasedservice"/>
                                      <xs:enumeration value="prescribing"/>
                                      <xs:enumeration value="rendering"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="http://terminology.hl7.org/CodeSystem/claimcareteamrole"/>
                                      <xs:enumeration value="http://hl7.org/fhir/us/carin-bb/CodeSystem/C4BBClaimCareTeamRole"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="qualification" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Practitioner credential or specialization.  More information can be found here:  http://hl7.org/fhir/R4/codesystem-provider-qualification.html
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="http://terminology.hl7.org/CodeSystem/ex-providerqualification"/>
                                      <xs:enumeration value="http://nucc.org/provider-taxonomy"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <!--Required segment for Institutional[Inpatient and Outpatient] and Professional-NonClinician Profile-->
              <xs:element name="diagnoses" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="diagnosis" minOccurs="0" maxOccurs="unbounded">
                      <xs:annotation>
                        <xs:documentation>
										Required segment for Institutional[Inpatient and Outpatient] and Professional-NonClinician Profile
									</xs:documentation>
                      </xs:annotation>
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="sequence" type="positiveInt" minOccurs="1" maxOccurs="1"/>
                          <xs:element name="diagnosis_code" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										ICD-10 Codes
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <!--diagnosisCode-->
                                <xs:element name="coding" minOccurs="1" maxOccurs="unbounded">
                                  <xs:complexType>
                                    <xs:sequence>
                                      <xs:element name="code" type="string" minOccurs="1" maxOccurs="1">
                                        <xs:annotation>
                                          <xs:documentation>
																ICD-10-CM Diagnosis Codes-Large list of codes hence no enumeration included
															</xs:documentation>
                                        </xs:annotation>
                                      </xs:element>
                                      <xs:element name="system" minOccurs="0" maxOccurs="1">
                                        <xs:simpleType>
                                          <xs:restriction base="string">
                                            <xs:enumeration value="http://hl7.org/fhir/sid/icd-10-cm"/>
                                            <xs:enumeration value="http://terminology.hl7.org/CodeSystem/icd9"/>
                                            <xs:enumeration value="http://hl7.org/fhir/sid/icd-10"/>
                                          </xs:restriction>
                                        </xs:simpleType>
                                      </xs:element>
                                      <!--ICD code version-->
                                      <xs:element name="version" type="string" minOccurs="0" maxOccurs="1"/>
                                      <xs:element name="display" type="string" minOccurs="0" maxOccurs="1">
                                        <xs:annotation>
                                          <xs:documentation>
																Diagnosis description
															</xs:documentation>
                                        </xs:annotation>
                                      </xs:element>
                                    </xs:sequence>
                                  </xs:complexType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="type" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Diagnosis type codes for inpatient, outpatient, nonclinician and pharmacy
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="principal"/>
                                      <xs:enumeration value="admitting"/>
                                      <xs:enumeration value="other"/>
                                      <xs:enumeration value="secondary"/>
                                      <xs:enumeration value="externalcauseofinjury"/>
                                      <xs:enumeration value="patientreasonforvisit"/>
                                      <!--only Pharmacy profile-->
                                      <xs:enumeration value="clinical"/>
                                      <xs:enumeration value="differential"/>
                                      <xs:enumeration value="discharge"/>
                                      <xs:enumeration value="laboratory"/>
                                      <xs:enumeration value="nursing"/>
                                      <xs:enumeration value="prenatal"/>
                                      <xs:enumeration value="radiology"/>
                                      <xs:enumeration value="remote"/>
                                      <xs:enumeration value="retrospective"/>
                                      <xs:enumeration value="self"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="http://terminology.hl7.org/CodeSystem/ex-diagnosistype"/>
                                      <xs:enumeration value="http://hl7.org/fhir/us/carin-bb/CodeSystem/C4BBClaimDiagnosisType"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="on_admission" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Diagnosis on Admission Codes.  More information can be found here:  http://hl7.org/fhir/R4/valueset-ex-diagnosis-on-admission.html
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="https://www.nubc.org/CodeSystem/PresentOnAdmissionIndicator"/>
                                      <xs:enumeration value="http://terminology.hl7.org/CodeSystem/ex-diagnosis-on-admission"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="package_code" type="string" minOccurs="0" maxOccurs="1"/>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="procedures" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="procedure" minOccurs="0" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="sequence" type="positiveInt" minOccurs="1" maxOccurs="1"/>
                          <!--ICD-10-PCS Codes-->
                          <xs:element name="procedure_code" minOccurs="1" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <!--Procedurecode-->
                                <xs:element name="coding" minOccurs="1" maxOccurs="unbounded">
                                  <xs:complexType>
                                    <xs:sequence>
                                      <!--Procedurecode-->
                                      <xs:element name="code" type="string" minOccurs="1" maxOccurs="1"/>
                                      <xs:element name="system" minOccurs="0" maxOccurs="1">
                                        <xs:simpleType>
                                          <xs:restriction base="string">
                                            <xs:enumeration value="http://www.ama-assn.org/go/cpt"/>
                                            <xs:enumeration value="http://snomed.info/sct"/>
                                            <xs:enumeration value="http://www.cms.gov/Medicare/Coding/ICD10"/>
                                            <xs:enumeration value="http://terminology.hl7.org/CodeSystem/CD2"/>
                                            <xs:enumeration value="urn:oid:2.16.840.1.113883.6.285"/>
                                            <xs:enumeration value="http://www.cms.gov/Medicare/Coding/ICD9"/>
                                            <xs:enumeration value="http://hl7.org/fhir/sid/ex-icd-10-procedures"/>
                                          </xs:restriction>
                                        </xs:simpleType>
                                      </xs:element>
                                      <xs:element name="version" type="string" minOccurs="0" maxOccurs="1"/>
                                      <!--ProcedureDescription-->
                                      <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
                                    </xs:sequence>
                                  </xs:complexType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <!--Procedure type-only required for Inpatient-Institutional-->
                          <xs:element name="type" minOccurs="0" maxOccurs="unbounded" type="string">
                            <xs:annotation>
                              <xs:documentation>
									                          Preferred codesets:principal,other
															</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="date" type="date" minOccurs="0" maxOccurs="1"/>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="precedence" type="positiveInt" minOccurs="0" maxOccurs="1"/>
              <xs:element name="insurances" minOccurs="1" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="insurance" minOccurs="1" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="is_focal" type="boolean" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Is Coverage to be used for adjudication
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="pre_auth_ref" type="string" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Prior authorization reference number
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Reference(CARIN BB Coverage)-->
                          <xs:element name="coverage" minOccurs="1" maxOccurs="1">
                            <xs:complexType>
                              <xs:choice>
                                <xs:group ref="coverage"/>
                                <xs:group ref="reference"/>
                              </xs:choice>
                            </xs:complexType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="items" minOccurs="0" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="item" minOccurs="0" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <!--Line number-->
                          <xs:element name="sequence" type="positiveInt" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Item instance identifier
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="care_team_sequence" type="positiveInt" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Applicable care team members
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="diagnosis_sequence" type="positiveInt" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Applicable diagnoses
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="procedure_sequence" type="positiveInt" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Applicable procedures
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="information_sequence" type="positiveInt" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Applicable exception and supporting information,Enumuration list is not published yet but required
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Revenue center code-->
                          <xs:element name="revenue" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Revenue or cost center code
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="system" minOccurs="0" maxOccurs="1" type="string">
                                  <xs:annotation>
                                    <xs:documentation>
									                          Required valid value for institutional profile:https://www.nubc.org/CodeSystem/RevenueCodes
															</xs:documentation>
                                  </xs:annotation>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <!--Type of service-->
                          <xs:element name="category" minOccurs="0" maxOccurs="1" type="string">
                            <xs:annotation>
                              <xs:documentation>
																Benefit classification.  More information can be found here:  http://hl7.org/fhir/R4/valueset-ex-benefitcategory.html
																Preferred code sets list:
																1	,2	,3	,4	,5	,14	,23	,24	,25	,26	,27	,28	,30	,35	,36	,37	,49	,55	,56	,61	,62	,63	,69	,76	,F1	,F3	,F4	,F6

															</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Compound code,National drug code-->
                          <xs:element name="product_or_service" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
																Current Procedural Terminology (CPT) - Healthcare Common Procedure Coding System (HCPCS) level II alphanumeric codes - Procedure Codes
																NDC or Compound
															</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" type="string" minOccurs="1" maxOccurs="1"/>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="http://www.ama-assn.org/go/cpt"/>
                                      <xs:enumeration value="http://www.cms.gov/Medicare/Coding/HCPCSReleaseCodeSets"/>
                                      <xs:enumeration value="http://hl7.org/fhir/sid/ndc"/>
                                      <xs:enumeration value="http://hl7.org/fhir/us/carin-bb/CodeSystem/C4BBCompoundLiteral"/>
                                      <xs:enumeration value="https://www.cms.gov/Medicare/Medicare-Fee-for-Service-Payment/ProspMedicareFeeSvcPmtGen/HIPPSCodes"/>
                                      <xs:enumeration value="http://terminology.hl7.org/CodeSystem/data-absent-reason"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                                <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="text" type="string" minOccurs="0" maxOccurs="1"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <!--Modifier Code -1,Modifier Code -2,Modifier Code -3,Modifier Code -4-->
                          <xs:element name="modifier" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										 Current Procedural Terminology (CPT) - Healthcare Common Procedure Coding System (HCPCS) level II alphanumeric codes - Procedure Modifier Codes
										  ModifierTypeCodes
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="system" minOccurs="0" maxOccurs="1">
                                  <xs:simpleType>
                                    <xs:restriction base="string">
                                      <xs:enumeration value="http://www.ama-assn.org/go/cpt"/>
                                      <xs:enumeration value="http://www.cms.gov/Medicare/Coding/HCPCSReleaseCodeSets"/>
                                      <xs:enumeration value="http://hl7.org/fhir/sid/ndc"/>
                                      <xs:enumeration value="http://hl7.org/fhir/us/carin-bb/CodeSystem/C4BBCompoundLiteral"/>
                                    </xs:restriction>
                                  </xs:simpleType>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="program_code" type="string" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Program Reason Codes
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="serviced" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Date or dates of service or product delivery
									</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                              <xs:sequence>
                                <xs:choice>
                                  <xs:element name="serviced_date" type="date" minOccurs="0" maxOccurs="1"/>
                                  <xs:element name="serviced_period" minOccurs="0" maxOccurs="1" type="period"/>
                                </xs:choice>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="quantity" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="value" type="decimal" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="unit" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="system" type="string" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="unit_price" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="value" type="decimal" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="currency" minOccurs="0" maxOccurs="1" type="currency">
                                  <xs:annotation>
                                    <xs:documentation>
													Currency codes which can be found here:  http://hl7.org/fhir/R4/valueset-currencies.html
												</xs:documentation>
                                  </xs:annotation>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <xs:element name="factor" type="decimal" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
										Price scaling factor
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Total item cost-->
                          <xs:element name="net" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="value" type="decimal" minOccurs="0" maxOccurs="1"/>
                                <xs:element name="currency" minOccurs="0" maxOccurs="1" type="currency">
                                  <xs:annotation>
                                    <xs:documentation>
													Currency codes which can be found here:  http://hl7.org/fhir/R4/valueset-currencies.html
												</xs:documentation>
                                  </xs:annotation>
                                </xs:element>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                          <!--Applicable note numbers-->
                          <xs:element name="note_number" type="positiveInt" minOccurs="0" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
										Applicable note numbers
									</xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Place of service or where product was supplied-->
                          <xs:element name="location" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:choice>
                                  <xs:element name="location_codeable_concept" minOccurs="0" maxOccurs="1" type="string"/>
                                  <xs:element name="location_address" minOccurs="0" maxOccurs="1" type="address"/>
                                  <xs:element name="location_reference" minOccurs="0" maxOccurs="1">
                                    <xs:annotation>
                                      <xs:documentation>
										Place of service or where product was supplied
									</xs:documentation>
                                    </xs:annotation>
                                    <xs:complexType>
                                      <xs:sequence>
                                        <xs:element name="identifier" minOccurs="0" maxOccurs="unbounded" type="identifier">
                                          <xs:annotation>
                                            <xs:documentation>
																Claim site of service NPI
															</xs:documentation>
                                          </xs:annotation>
                                        </xs:element>
                                        <xs:element name="name" type="string" minOccurs="0" maxOccurs="1">
                                          <xs:annotation>
                                            <xs:documentation>
