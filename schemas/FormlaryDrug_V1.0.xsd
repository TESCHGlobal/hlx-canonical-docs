                <xs:annotation>
                    <xs:documentation>
						A list of Quantity Comparator's can be found here:  http://hl7.org/fhir/R4/valueset-quantity-comparator.html
					</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:enumeration value="&lt;"/>
                        <xs:enumeration value="&lt;="/>
                        <xs:enumeration value=">="/>
                        <xs:enumeration value=">"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="unit" minOccurs="0" maxOccurs="1" type="string">
                <xs:annotation>
                    <xs:documentation>
						Unit representation (e.g. mcg)
					</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="system" minOccurs="0" maxOccurs="1" type="string">
                <xs:annotation>
                    <xs:documentation>
						The URI of the system that defines the coded unit form
					</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="code" minOccurs="0" maxOccurs="1" type="string">
                <xs:annotation>
                    <xs:documentation>
						Coded form of the unit
					</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:element name="formulary_drugs">
        <xs:annotation>
            <xs:documentation> The FormularyDrug resource represents a drug that is part of a drug formulary. A drug formulary is a list of brand-name and generic prescription drugs a health insurer agrees to pay for, at least partially, as part of health insurance coverage.In addition to identifying the drug by its RxNorm code, and the PlanID of the formulary, the FormularyDrug entry provides information on prescribing limitations, and optionally drug classification and alternatives
            </xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:sequence>
            <!--The FormularyDrug resource represents a drug that is part of a drug formulary. A drug formulary is a list of brand-name and generic prescription drugs a health insurer agrees to pay for, at least partially, as part of health insurance coverage.In addition to identifying the drug by its RxNorm code, and the PlanID of the formulary, the FormularyDrug entry provides information on prescribing limitations, and optionally drug classification and alternatives-->
            <xs:element name="formulary_drug" minOccurs="1" maxOccurs="unbounded">
                <xs:complexType>
                    <xs:sequence>
                        <!--Code that identifies this medication-->
                        <xs:element name="rx_norm_code" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>
									A list of RxNorm Codes can be found here:  http://hl7.org/fhir/us/core/STU3/ValueSet-us-core-medication-codes.html
								</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="code" minOccurs="1" maxOccurs="1"
                                        type="string"/>

                                    <xs:element name="display" type="string" minOccurs="1"
                                        maxOccurs="1"/>
                                    <xs:element name="system" minOccurs="1" maxOccurs="1">
                                        <xs:simpleType>
                                            <xs:restriction base="string">
                                                <xs:enumeration
                                                  value="http://www.nlm.nih.gov/research/umls/rxnorm"
                                                />
                                            </xs:restriction>
                                        </xs:simpleType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="status" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>
									Status of medication.  Status options can be found here:  http://hl7.org/fhir/R4/valueset-medicationknowledge-status.html
								</xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                                <xs:restriction base="string">
                                    <xs:enumeration value="active"/>
                                    <xs:enumeration value="inactive"/>
                                    <xs:enumeration value="entered-in-error"/>
                                </xs:restriction>
                            </xs:simpleType>
                        </xs:element>
                        <xs:element name="manufacturer" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>
									Manufacturer of the medication
								</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="name" type="string" minOccurs="1"
                                        maxOccurs="1"/>
                                    <xs:element name="alias" type="string" minOccurs="0"
                                        maxOccurs="unbounded"/>
                                    <xs:element name="type" minOccurs="0" maxOccurs="unbounded">
                                        <xs:annotation>
                                            <xs:documentation>
												Select the type of orginzation this is.  A full list can be found here:  http://hl7.org/fhir/R4/valueset-organization-type.html
											</xs:documentation>
                                        </xs:annotation>
                                        <xs:simpleType>
                                            <xs:union>
                                                <xs:simpleType>
                                                  <xs:restriction base="string">
                                                  <xs:enumeration value="prov"/>
                                                  <xs:enumeration value="dept"/>
                                                  <xs:enumeration value="team"/>
                                                  <xs:enumeration value="govt"/>
                                                  <xs:enumeration value="ins"/>
                                                  <xs:enumeration value="pay"/>
                                                  <xs:enumeration value="edu"/>
                                                  <xs:enumeration value="reli"/>
                                                  <xs:enumeration value="crs"/>
                                                  <xs:enumeration value="tecgam"/>
                                                  <xs:enumeration value="bus"/>
                                                  <xs:enumeration value="other"/>
                                                  </xs:restriction>
                                                </xs:simpleType>
                                                <xs:simpleType>
                                                  <xs:union memberTypes="xs:string"/>
                                                </xs:simpleType>
                                            </xs:union>
                                        </xs:simpleType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="dose_form" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>
												Select the dose form.  A full list can be found here:  http://hl7.org/fhir/R4/valueset-medication-form-codes.html
											</xs:documentation>
                            </xs:annotation>
