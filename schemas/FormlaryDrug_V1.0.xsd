                        <xs:element name="cost_informations" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="cost_information" minOccurs="0"
                                        maxOccurs="unbounded">
                                        <xs:annotation>
                                            <xs:documentation>
										The price of the medication
								</xs:documentation>
                                        </xs:annotation>
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="type" type="string" minOccurs="1"
                                                  maxOccurs="1">
                                                  <xs:annotation>
                                                  <xs:documentation>The category of the cost information. For example, manufacturers' cost, patient cost, claim reimbursement cost, actual acquisition cost.</xs:documentation>
                                                  </xs:annotation>
                                                </xs:element>
                                                <xs:element name="source" type="string"
                                                  minOccurs="0" maxOccurs="1">
                                                  <xs:annotation>
                                                  <xs:documentation>The source or owner for the price information</xs:documentation>
                                                  </xs:annotation>
                                                </xs:element>
                                                <xs:element name="cost" minOccurs="1" maxOccurs="1">
                                                  <xs:annotation>
                                                  <xs:documentation>The actual cost of the medication</xs:documentation>
                                                  </xs:annotation>
                                                  <xs:complexType>
                                                  <xs:sequence>
                                                  <xs:element name="value" type="decimal"
                                                  minOccurs="0" maxOccurs="1"/>
                                                  <xs:element name="currency" minOccurs="0"
                                                  maxOccurs="1" type="currency">
                                                  <xs:annotation>
                                                  <xs:documentation>
															Currency codes which can be found here:  http://hl7.org/fhir/R4/valueset-currencies.html
														</xs:documentation>
                                                  </xs:annotation>
                                                  </xs:element>
                                                  </xs:sequence>

                                                  </xs:complexType>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="plan_id" type="string" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation> Plan IDs must be unique, even across different markets.
								</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="drug_tier_id" minOccurs="1" maxOccurs="1">
                            <xs:complexType>

                                <xs:annotation>
                                    <xs:documentation>
												A code that describes the coverage status of a drug in a health plan (generic, preferred-generic, non-preferred-generic, specialty, brand, preferred-brand, non-preferred-brand, zero-cost-share-preventive, medical-service).  More inoformation can be found here:  http://hl7.org/fhir/us/Davinci-drug-formulary/ValueSet-usdf-DrugTierVS.html
												at least supply one or the other- "code" or "text"
										</xs:documentation>
                                </xs:annotation>
                                <xs:choice>
                                    <xs:element name="code">
                                        <xs:simpleType>
                                            <xs:restriction base="string">
                                                <xs:enumeration value="generic"/>
                                                <xs:enumeration value="preferred-generic"/>
                                                <xs:enumeration value="non-preferred-generic"/>
                                                <xs:enumeration value="specialty"/>
                                                <xs:enumeration value="brand"/>
                                                <xs:enumeration value="preferred-brand"/>
                                                <xs:enumeration value="non-preferred-brand"/>
                                                <xs:enumeration value="zero-cost-share-preventive"/>
                                                <xs:enumeration value="medical-service"/>
                                            </xs:restriction>
                                        </xs:simpleType>
                                    </xs:element>
                                    <xs:element name="text" type="string"/>
                                </xs:choice>
                            </xs:complexType>
                        </xs:element>
                        <xs:element name="prior_authorization" type="boolean" minOccurs="0"
                            maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>A Boolean indication of whether the coverage plan imposes a prior authorization requirement on this drug</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="step_therapy" type="boolean" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>A Boolean indication of whether the coverage plan imposes a step therapy limit on this drug</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="quantity_limit" type="boolean" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                                <xs:documentation>A Boolean indication of whether the coverage plan imposes a quantity limit on this drug</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="mail_order" type="boolean" minOccurs="1" maxOccurs="1"/>
                        <xs:element name="medicine_classifications" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="medicine_classification" minOccurs="0"
                                        maxOccurs="unbounded">
                                        <xs:annotation>
                                            <xs:documentation>The type of category for the medication (for example, therapeutic classification, therapeutic sub-classification)</xs:documentation>
                                        </xs:annotation>
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="type" type="string" minOccurs="1"
                                                  maxOccurs="1"/>
                                                <!--	Specific category assigned to the medication-->
                                                <xs:element name="classification" type="string"
                                                  minOccurs="0" maxOccurs="unbounded"/>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>

                        <xs:element name="formulary_drug_alternatives" minOccurs="0" maxOccurs="1">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="alternative_rx_norm_code" minOccurs="1"
                                        maxOccurs="unbounded" type="string"/>
                                </xs:sequence>

                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        </xs:complexType>
    </xs:element>
