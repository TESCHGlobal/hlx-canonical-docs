                                                  maxOccurs="1">
                                                  <xs:annotation>
                                                  <xs:documentation>Type of program under which the medication is monitored</xs:documentation>
                                                  </xs:annotation>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
