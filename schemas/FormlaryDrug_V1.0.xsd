                                            <xs:documentation>
												Program under which a medication is reviewed
										</xs:documentation>
                                        </xs:annotation>
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="name" type="string" minOccurs="0"
                                                  maxOccurs="1"/>
