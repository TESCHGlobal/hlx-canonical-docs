<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning" attributeFormDefault="unqualified" elementFormDefault="qualified" vc:minVersion="1.1" version="6.1">
  <xs:simpleType name="string">
    <xs:restriction base="xs:string">
      <xs:pattern value="[ \r\n\t\S]+"/>
    </xs:restriction>
  </xs:simpleType>
  <!--Regular Expression for Positive Integer-->
  <xs:simpleType name="positiveInt">
    <xs:restriction base="xs:positiveInteger">
      <xs:pattern value="\+?[1-9][0-9]*"/>
    </xs:restriction>
  </xs:simpleType>
  <!--Regular Expression for unsignedInt Integer-->
  <xs:simpleType name="unsignedInt">
    <xs:restriction base="xs:unsignedInt">
      <xs:pattern value="0|([1-9][0-9]*)"/>
    </xs:restriction>
  </xs:simpleType>
  <!--Regular Expression for Integer-->
  <xs:simpleType name="integer">
    <xs:restriction base="xs:integer">
      <xs:pattern value="[0]|[-+]?[1-9][0-9]*"/>
    </xs:restriction>
  </xs:simpleType>
  <!--Regular Expression for Date-->
  <xs:simpleType name="date">
    <xs:restriction base="xs:date">
      <xs:pattern value="([12]\d{3}-(0[1-9]|1[0-2])-(0[1-9]|[12]\d|3[01]))"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="boolean">
    <xs:restriction base="xs:boolean">
      <xs:pattern value="true|false"/>
    </xs:restriction>
  </xs:simpleType>
  <!--Regular Expression for DateTime-->
  <xs:simpleType name="dateTime">
    <xs:restriction base="xs:string">
      <xs:pattern value="([12]\d{3})-(0[1-9]|1[0-2])-(0[1-9]|[1-2][0-9]|3[0-1])(T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\.\d{1,6})?((Z|(\+|-)((0[0-9]|1[0-3]):(00|15|30|45)|14:00))?))?"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:complexType name="period">
    <xs:sequence>
      <xs:element maxOccurs="1" minOccurs="0" name="start" type="dateTime"/>
      <xs:element maxOccurs="1" minOccurs="0" name="end" type="dateTime"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="identifier">
    <xs:sequence>
      <xs:element maxOccurs="1" minOccurs="1" name="value" type="string"/>
      <xs:element maxOccurs="1" minOccurs="1" name="type" type="string"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="organization">
    <xs:sequence>
      <!--Claim billing provider NPI-->
      <xs:element maxOccurs="unbounded" minOccurs="0" name="tax" type="identifier">
        <xs:annotation>
          <xs:documentation>
							Tax Id Number
						</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="unbounded" minOccurs="0" name="naic_code" type="identifier"/>
      <!--Payer ID-->
      <xs:element maxOccurs="unbounded" minOccurs="0" name="payer_id" type="identifier"/>
      <xs:element maxOccurs="1" minOccurs="1" name="is_active" type="boolean"/>
      <xs:element maxOccurs="1" minOccurs="1" name="name" type="string"/>
      <xs:element maxOccurs="unbounded" minOccurs="0" name="alias" type="string"/>
      <xs:element maxOccurs="1" minOccurs="0" name="telecoms">
        <xs:complexType>
          <xs:sequence>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="telecom" type="telecom"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="addresses">
        <xs:complexType>
          <xs:sequence>
            <xs:element maxOccurs="unbounded" minOccurs="0" name="address" type="address"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="telecom">
    <xs:sequence>
      <xs:element maxOccurs="1" minOccurs="1" name="system">
        <xs:annotation>
          <xs:documentation>
						Use this element to descripbe the contact point.  https://www.hl7.org/fhir/valueset-contact-point-system.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="phone"/>
            <xs:enumeration value="fax"/>
            <xs:enumeration value="email"/>
            <xs:enumeration value="pager"/>
            <xs:enumeration value="url"/>
            <xs:enumeration value="sms"/>
            <xs:enumeration value="other"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--	The actual contact point details-->
      <xs:element maxOccurs="1" minOccurs="1" name="value" type="string">
        <xs:annotation>
          <xs:documentation>
						The actual value of the contact point
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="use">
        <xs:annotation>
          <xs:documentation>
						The use of the contact point.  https://www.hl7.org/fhir/valueset-contact-point-use.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="home"/>
            <xs:enumeration value="work"/>
            <xs:enumeration value="temp"/>
            <xs:enumeration value="old"/>
            <xs:enumeration value="mobile"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="rank" type="positiveInt">
        <xs:annotation>
          <xs:documentation>
						Specify preferred order of use (1 = highest)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Time period when the contact point was/is in use-->
      <xs:element maxOccurs="1" minOccurs="0" name="period" type="period">
        <xs:annotation>
          <xs:documentation>
						Time period when the contact point was/is in use
					</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="address">
    <xs:sequence>
      <!--Choose from code ValueSet- home | work | temp | old | billing - purpose of this address-->
      <xs:element maxOccurs="1" minOccurs="0" name="use">
        <xs:annotation>
          <xs:documentation>
						The use of this address.  More information can be found here:  http://hl7.org/fhir/R4/valueset-address-use.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="home"/>
            <xs:enumeration value="work"/>
            <xs:enumeration value="temp"/>
            <xs:enumeration value="old"/>
            <xs:enumeration value="billing"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Choose from code ValueSet- postal | physical | both-->
      <xs:element maxOccurs="1" minOccurs="0" name="type">
        <xs:annotation>
          <xs:documentation>
						The type of address.  More information can be found here:  http://hl7.org/fhir/R4/valueset-address-type.html
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="string">
            <xs:enumeration value="postal"/>
            <xs:enumeration value="physical"/>
            <xs:enumeration value="both"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Text representation of the address-->
      <xs:element maxOccurs="1" minOccurs="0" name="text" type="string">
        <xs:annotation>
          <xs:documentation>
						Use this element to list the address in it's entirety (e.g. 123 Test Way City, State 12345)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--Street name, number, direction & P.O. Box etc.-->
      <xs:element maxOccurs="unbounded" minOccurs="0" name="line" type="string"/>
      <xs:element maxOccurs="1" minOccurs="1" name="city" type="string">
        <xs:annotation>
          <xs:documentation>
						Name of city, town etc.
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <!--District name (aka county)-->
      <xs:element maxOccurs="1" minOccurs="0" name="district" type="string">
        <xs:annotation>
          <xs:documentation>
						Use this element to list the District name (aka county)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="1" name="state" type="string">
        <xs:annotation>
          <xs:documentation>
						Sub-unit of country (abbreviations ok)
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="1" name="postal_code" type="string">
        <xs:annotation>
          <xs:documentation>
						The postal code or post code of the address.  The postal code supports an unlimited amount of numbers and letters.
					</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element maxOccurs="1" minOccurs="0" name="country">
        <xs:annotation>
          <xs:documentation>
						Country (e.g. can be ISO 3166 2 or 3 letter code)
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="2"/>
            <xs:maxLength value="3"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!--Time period when address was/is in use-->
      <xs:element maxOccurs="1" minOccurs="0" name="period" type="period"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="coding">
    <xs:sequence>
      <xs:element name="system" type="string" minOccurs="0" maxOccurs="1"/>
      <xs:element name="code" type="string" minOccurs="0" maxOccurs="1"/>
      <xs:element name="display" type="string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="codeable_concept">
    <xs:sequence>
      <xs:element name="coding" type="coding" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="text" type="string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
  </xs:complexType>
