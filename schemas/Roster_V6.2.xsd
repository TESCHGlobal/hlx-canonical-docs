                      <xs:annotation>
                        <xs:documentation>
                                                    Use this element for the secret value when SSN is not available
                                                </xs:documentation>
                      </xs:annotation>
                    </xs:element>
                    <xs:element maxOccurs="1" minOccurs="0" name="secret_length" type="unsignedInt">
                      <xs:annotation>
                        <xs:documentation>
                                                    Use this element for the secret length when SSN is not available
                                                </xs:documentation>
                      </xs:annotation>
                    </xs:element>
                  </xs:sequence>
                  <!--<xs:assert
                                        test="(member_last_4_ssn and not(secret_display_name) and not(secret_value) and not(secret_length)) or (not(member_last_4_ssn) and secret_display_name and secret_value and secret_length)"
                                    />-->
                </xs:complexType>
              </xs:element>
              <xs:element maxOccurs="1" minOccurs="1" name="member_id" type="string">
                <xs:annotation>
                  <xs:documentation>
                                        Use this element to list the Member Number. 
                                    </xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element maxOccurs="1" minOccurs="0" name="member_id_system" type="string">
                <xs:annotation>
                  <xs:documentation>
										Use this element to identify the system that issues the Member ID . 
									</xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element maxOccurs="1" minOccurs="1" name="subscriber_id" type="string">
                <xs:annotation>
                  <xs:documentation>
                                        Use this element to list the Subscriber Number.  An identifier for a subscriber of an insurance policy which is unique for, and usually assigned by, the insurance carrier. Use Case: A person is the subscriber of an insurance policy. The person’s family may be plan members, but are not the subscriber.
                                    </xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element minOccurs="1" maxOccurs="1" name="names">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element maxOccurs="unbounded" minOccurs="1" name="name">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element maxOccurs="1" minOccurs="0" name="use">
                            <xs:annotation>
                              <xs:documentation>
                                                    Use this element to describe the name.  More information can be found here:  http://hl7.org/fhir/R4/valueset-name-use.html
                                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="usual"/>
                                <xs:enumeration value="official"/>
                                <xs:enumeration value="temp"/>
                                <xs:enumeration value="nickname"/>
                                <xs:enumeration value="anonymous"/>
                                <xs:enumeration value="old"/>
                                <xs:enumeration value="maiden"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="1" name="text" type="string">
                            <xs:annotation>
                              <xs:documentation>
                                                    Use this element to enter the entire name of the member
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="family" type="string" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                        Family name (often called 'Surname') (Note:  At least Family or Given need to be filled in)
                                                    </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="given" type="string" minOccurs="1" maxOccurs="unbounded">
                            <xs:annotation>
                              <xs:documentation>
                                                        Given names (not always 'first'). Includes middle names
                                                    </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="0" name="prefix" type="string"/>
                          <xs:element maxOccurs="1" minOccurs="0" name="suffix" type="string"/>
                          <xs:element maxOccurs="1" minOccurs="0" name="period" type="period">
                            <xs:annotation>
                              <xs:documentation>
                                                    Time period when name was/is in use.  If the name is still in use, do not supply an End date
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element minOccurs="0" maxOccurs="1" name="telecoms">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element maxOccurs="unbounded" minOccurs="1" name="telecom">
                      <xs:annotation>
                        <xs:documentation>
                                        Contact points of telecommunications.  Please provide at least one form of contact (e.g. phone, email, etc.)
                                    </xs:documentation>
                      </xs:annotation>
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="system" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                    Use this element to descripbe the contact point.  https://www.hl7.org/fhir/valueset-contact-point-system.html
                                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="phone"/>
                                <xs:enumeration value="fax"/>
                                <xs:enumeration value="email"/>
                                <xs:enumeration value="pager"/>
                                <xs:enumeration value="url"/>
                                <xs:enumeration value="sms"/>
                                <xs:enumeration value="other"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <!--	The actual contact point details-->
                          <xs:element name="value" type="string" minOccurs="1" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                    The actual value of the contact point.  This is a free form text field allowing country and extension. (e.g. (+001) 111-111-1111 x1111)
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="use" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                    The use of the contact point.  https://www.hl7.org/fhir/valueset-contact-point-use.html
                                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="home"/>
                                <xs:enumeration value="work"/>
                                <xs:enumeration value="temp"/>
                                <xs:enumeration value="old"/>
                                <xs:enumeration value="mobile"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="rank" type="positiveInt" minOccurs="0" maxOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                    Specify preferred order of use (1 = highest)
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <!--Time period when the contact point was/is in use-->
                          <xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
                            <xs:annotation>
                              <xs:documentation>
                                                    Time period when the contact point was/is in use
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element maxOccurs="1" minOccurs="0" name="addresses">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element maxOccurs="unbounded" minOccurs="1" name="address">
                      <xs:annotation>
                        <xs:documentation>
                                        Use this element to list all the addresses the member is associated with.  It is recommended that at least one address be supplied for identification purposes.
                                    </xs:documentation>
                      </xs:annotation>
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element maxOccurs="1" minOccurs="0" name="use">
                            <xs:annotation>
                              <xs:documentation>
                                                    The use of this address.  More information can be found here:  http://hl7.org/fhir/R4/valueset-address-use.html
                                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="home"/>
                                <xs:enumeration value="work"/>
                                <xs:enumeration value="temp"/>
                                <xs:enumeration value="old"/>
                                <xs:enumeration value="billing"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="0" name="type">
                            <xs:annotation>
                              <xs:documentation>
                                                    The type of address.  More information can be found here:  http://hl7.org/fhir/R4/valueset-address-type.html
                                                </xs:documentation>
                            </xs:annotation>
                            <xs:simpleType>
                              <xs:restriction base="string">
                                <xs:enumeration value="postal"/>
                                <xs:enumeration value="physical"/>
                                <xs:enumeration value="both"/>
                              </xs:restriction>
                            </xs:simpleType>
                          </xs:element>
                          <xs:element name="text" maxOccurs="1" minOccurs="1" type="string">
                            <xs:annotation>
                              <xs:documentation>
                                                    Use this element to list the address in it's entirety (e.g. 123 Test Way City, State 12345)
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="line" maxOccurs="unbounded" minOccurs="0" type="string"/>
                          <xs:element name="city" maxOccurs="1" minOccurs="0" type="string"/>
                          <xs:element name="district" maxOccurs="1" minOccurs="0" type="string">
                            <xs:annotation>
                              <xs:documentation>
                                                    Use this element to list the District name (aka county)
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element name="state" maxOccurs="1" type="string" minOccurs="0"/>
                          <xs:element name="postal_code" maxOccurs="1" minOccurs="0" type="string"/>
                          <xs:element name="country" maxOccurs="1" type="string" minOccurs="1">
                            <xs:annotation>
                              <xs:documentation>
                                                    Country (e.g. can be ISO 3166 2 or 3 letter code)
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                          <xs:element maxOccurs="1" minOccurs="0" name="period" type="period">
                            <xs:annotation>
                              <xs:documentation>
                                                    Time period when this address was/is in use.  If the address is still in use, do not supply an End date.  Format is YYYY-MM-DD.
                                                </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element maxOccurs="1" minOccurs="1" name="health_coverage">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element maxOccurs="1" minOccurs="0" name="group_number" type="string"/>
                    <xs:element maxOccurs="1" minOccurs="0" name="policy_number" type="string">
                      <xs:annotation>
                        <xs:documentation>
													Each person covered by a health insurance plan has a unique ID number that allows healthcare providers and their staff to verify coverage and arrange payment for services.
													
													This is also known as member number and/or card-id and or member-id.
												</xs:documentation>
                      </xs:annotation>
                    </xs:element>
                    <xs:element maxOccurs="1" minOccurs="1" name="plan_id" type="string">
                      <xs:annotation>
                        <xs:documentation>
													The Identifier of the plan associated with the Plan Name
												</xs:documentation>
                      </xs:annotation>
                    </xs:element>
                    <xs:element maxOccurs="1" minOccurs="1" name="plan_name" type="string"/>
                    <xs:element maxOccurs="1" minOccurs="0" name="coverage_status" type="string">
                      <xs:annotation>
                        <xs:documentation>
                          Indicates the current status of coverage for the member. Must be one of: active, cancelled, draft, entered-in-error
                        </xs:documentation>
                      </xs:annotation>
                    </xs:element>
                    <xs:element minOccurs="0" maxOccurs="1" name="coverage_type">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="codeable_concept" type="codeable_concept">
                            <xs:annotation>
                              <xs:documentation>
                                Category of healthcare payers, insurance products, or benefits.
                              </xs:documentation>
                            </xs:annotation>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                    <xs:element maxOccurs="1" minOccurs="1" name="coverage_period" type="period">
                      <xs:annotation>
                        <xs:documentation>
                          Use this element to provide dates of coverage for this member.  If the coverage is still active, do not provide an End date.  Format is YYYY-MM-DD.
                        </xs:documentation>
                      </xs:annotation>
                    </xs:element>
                    <xs:element maxOccurs="1" minOccurs="0" name="network_id" type="string">
                      <xs:annotation>
                        <xs:documentation>
													network associated with the plan
												</xs:documentation>
                      </xs:annotation>
                    </xs:element>
                    <xs:element name="payor" minOccurs="0" type="organization">
                      <xs:annotation>
                        <xs:documentation>
													Payer Identifier-Issuer of the Policy
												</xs:documentation>
                      </xs:annotation>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
