	<xs:complexType name="networks">
		<xs:sequence>
			<xs:element name="network" minOccurs="1" maxOccurs="unbounded">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="network_id" type="network_id" minOccurs="1" maxOccurs="1">
							<xs:annotation>
								<xs:documentation>
								Unique Identifier of this Network
							</xs:documentation>
							</xs:annotation>
						</xs:element>
						<!--name of the network-->
						<xs:element name="name" type="string" minOccurs="0" maxOccurs="1">
							<xs:annotation>
								<xs:documentation>
								Name of this Network
							</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="period">
		<xs:sequence>
			<xs:element name="start" type="dateTime" minOccurs="0" maxOccurs="1"/>
			<xs:element name="end" type="dateTime" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="new_patients">
		<xs:sequence>
			<xs:element name="accepting_patients" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						New Patients indicates whether new patients are being accepted in general, or from a specific network.If no new patients are accepted, no characteristics are allowed
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="no"/>
						<xs:enumeration value="yes"/>
						<xs:enumeration value="existing"/>
						<xs:enumeration value="existingplusfamily"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="from_network" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="network_id" type="network_id" minOccurs="1" maxOccurs="1">
							<xs:annotation>
								<xs:documentation>
								Unique Identifier of this Network
							</xs:documentation>
							</xs:annotation>
						</xs:element>
						<!--name of the network-->
						<xs:element name="name" type="string" minOccurs="0" maxOccurs="1">
							<xs:annotation>
								<xs:documentation>
								Name of this Network
							</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="characteristics" type="string" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>
						Open text for additional information
					</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="not_available">
		<xs:sequence>
			<xs:element name="description" type="string" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
							Description of why the dates are not available
						</xs:documentation>
				</xs:annotation>
			</xs:element>
			<!--	Service not available from this date-->
			<xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
				<xs:annotation>
					<xs:documentation>
							Start/End dates when service is not available
						</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="available_time">
		<xs:sequence>
			<xs:element name="all_day" type="boolean" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Available All Day
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="days_of_week" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>
						Days of the week available
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="mon"/>
						<xs:enumeration value="tue"/>
						<xs:enumeration value="wed"/>
						<xs:enumeration value="thu"/>
						<xs:enumeration value="fri"/>
						<xs:enumeration value="sat"/>
						<xs:enumeration value="sun"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="available_start_time" type="time" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Opening time of day (ignored if all_day = true)
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="available_end_time" type="time" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						Closing time of day (ignored if all_day = true)
					</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="human_name">
		<xs:sequence>
			<xs:element name="use" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
					use this element to describe the name.  More information can be found here:  http://hl7.org/fhir/R4/valueset-name-use.html
				</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="usual"/>
						<xs:enumeration value="official"/>
						<xs:enumeration value="temp"/>
						<xs:enumeration value="nickname"/>
						<xs:enumeration value="anonymous"/>
						<xs:enumeration value="old"/>
						<xs:enumeration value="maiden"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element minOccurs="0" maxOccurs="1" name="text" type="string"/>
			<xs:element name="family" type="string" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						family name (often called &apos;Surname&apos;) 
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="given" type="string" maxOccurs="unbounded" minOccurs="0">
				<xs:annotation>
					<xs:documentation>
						Given names (not always &apos;first&apos;). Includes middle names
					</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element maxOccurs="unbounded" minOccurs="0" name="prefix" type="string"/>
			<xs:element maxOccurs="unbounded" minOccurs="0" name="suffix" type="string"/>
			<xs:element maxOccurs="1" minOccurs="0" name="period" type="period">
				<xs:annotation>
					<xs:documentation>
					Time period when name was/is in use.  If the name is still in use, do not supply an End date
				</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="organization_branch">
		<xs:sequence>
			<xs:element name="identifier" type="identifier" minOccurs="0" maxOccurs="1"/>
			<xs:element name="period" minOccurs="0" maxOccurs="1" type="period">
				<xs:annotation>
					<xs:documentation>
				Time period when id is/was valid for use
			</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="is_active" type="boolean" minOccurs="0" maxOccurs="1"/>
			<xs:element name="type" minOccurs="0" maxOccurs="1" type="type_of_organization">
				<xs:annotation>
					<xs:documentation>
					Select the type of orginzation this is.  A full list can be found here:  https://build.fhir.org/ig/HL7/davinci-pdex-plan-net/ValueSet-OrgTypeVS.html
				</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="name" type="string" minOccurs="1" maxOccurs="1"/>
			<xs:element name="alias" type="string" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="telecoms" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="telecom" minOccurs="0" maxOccurs="unbounded" type="telecom_minimum"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="addresses" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="address" minOccurs="0" maxOccurs="unbounded" type="address"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="contacts"  minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="contact"  minOccurs="0" maxOccurs="unbounded">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="purpose" minOccurs="0" maxOccurs="1">
										<xs:annotation>
											<xs:documentation>
								The purpose of this contact within is within the organization.  A full list can be found here:  https://www.hl7.org/fhir/valueset-contactentity-type.html
								</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="string">
												<xs:enumeration value="BILL"/>
												<xs:enumeration value="ADMIN"/>
												<xs:enumeration value="HR"/>
												<xs:enumeration value="PAYOR"/>
												<xs:enumeration value="PATINF"/>
												<xs:enumeration value="PRESS"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:element>
									<xs:element name="name" type="human_name" minOccurs="0" maxOccurs="1"/>
									<xs:element name="telecoms" minOccurs="0" maxOccurs="1">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="telecom" minOccurs="0" maxOccurs="unbounded" type="telecom_minimum"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="address" minOccurs="0" maxOccurs="1" type="address"/>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="telecom_minimum">
		<xs:sequence>
			<xs:element name="system" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						use this element to descripbe the contact point.  https://www.hl7.org/fhir/valueset-contact-point-system.html
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="string">
						<xs:enumeration value="phone"/>
						<xs:enumeration value="fax"/>
						<xs:enumeration value="email"/>
						<xs:enumeration value="pager"/>
						<xs:enumeration value="url"/>
						<xs:enumeration value="sms"/>
						<xs:enumeration value="other"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="value" type="string" minOccurs="1" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>
						The actual value of the contact point
